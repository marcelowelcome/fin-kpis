# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API de Dados do Monde (mirror somente-leitura)
# Chave da API de Dados, enviada no header `x-api-key`. É a ÚNICA fonte de
# vendas do dashboard (a API do Monde v3 não é mais consultada). Necessária
# para o botão "Atualizar", os crons (/api/cron/monde-sync, /api/monde/sync)
# e a Edge Function `monde-sync` (lá, configure como secret do Supabase).
# Opcional: MONDE_DATA_URL sobrescreve a base (default: função monde-data).
MONDE_DATA_API_KEY=your-monde-data-api-key

# Cron (Vercel)
# Segredo que protege o endpoint /api/cron/monde-sync. O Vercel injeta
# `Authorization: Bearer <CRON_SECRET>` nas chamadas agendadas (vercel.json).
# Gere um valor aleatório e configure o mesmo no painel do Vercel.
CRON_SECRET=your-random-cron-secret
