# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Monde API v3
# Credencial Basic Auth da API de Vendas v3 do Monde.
# Usada em `Authorization: Basic <valor>` — cole exatamente o que vem
# depois de "Basic ", sem re-codificar. Necessária para o botão
# "Atualizar" do dashboard e para o sync automático (/api/monde/sync).
MONDE_V3_API_KEY=your-monde-basic-auth-token

# Cron (Vercel)
# Segredo que protege o endpoint /api/cron/monde-sync. O Vercel injeta
# `Authorization: Bearer <CRON_SECRET>` nas chamadas agendadas (vercel.json).
# Gere um valor aleatório e configure o mesmo no painel do Vercel.
CRON_SECRET=your-random-cron-secret
